# ELAMS Server Environment Variables
# Copy this file as .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/elams?retryWrites=true&w=majority

# JWT Secret (use a long random string in production)
JWT_SECRET=elams_super_secret_key_change_in_production_2024

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
